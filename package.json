{
  "name": "promptkeep",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@11.5.0",
  "description": "PromptKeep — store, search, version, and reuse your system prompts. macOS desktop app + website.",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "pnpm --filter ui-aurora tauri dev",
    "web": "pnpm --filter ui-aurora dev",
    "build": "pnpm --filter ui-aurora tauri build",
    "build:web": "pnpm --filter ui-aurora build",
    "preview:web": "pnpm --filter ui-aurora preview",
    "typecheck": "pnpm -r typecheck",
    "test:core": "cargo test -p promptkeep-core"
  }
}
