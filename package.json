{
  "name": "system-prompt-library",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.5.0",
  "description": "A clean macOS desktop app for storing, searching, versioning and reusing system prompts.",
  "scripts": {
    "dev": "pnpm --filter ui-aurora tauri dev",
    "web": "pnpm --filter ui-aurora dev",
    "build": "pnpm --filter ui-aurora tauri build",
    "typecheck": "pnpm -r typecheck",
    "test:core": "cargo test -p spl-core"
  }
}
