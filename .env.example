# Community feature (Supabase). Copy this file to `.env` and fill in your
# project's values. All four UIs read this single root file.
#
# Find these in the Supabase dashboard for your `system-prompt-tracker` project:
#   Project Settings → API → Project URL  and  Project API keys → "anon" / publishable key.
# The anon key is safe to embed in the client — row-level security governs access.
#
# Leave these blank/unset and the Community tab simply shows its "coming online"
# state; everything else in the app works without Supabase.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
