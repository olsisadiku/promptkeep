# Supabase configuration. Copy this file to `.env` and fill in your project's
# values. All UIs read this single root file.
#
# Find these in the Supabase dashboard for your `system-prompt-tracker` project:
#   Project Settings → API → Project URL  and  Project API keys → "anon" / publishable key.
# The anon key is safe to embed in the client — row-level security governs access.
#
# DESKTOP app: these are OPTIONAL. Leave them blank and the Community tab simply
#   shows its "coming online" state; the local library, history, AI and Git
#   backup all work without Supabase.
#
# WEBSITE (the `pnpm build:web` / Vercel build): these are REQUIRED. The web app
#   has no local filesystem, so a signed-in user's library lives in Supabase.
#   Apply BOTH migrations first (supabase/migrations/0001_community.sql and
#   0002_library.sql). On Vercel, set these as Environment Variables instead of
#   committing a .env file.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
